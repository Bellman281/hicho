# Copy to .env and adjust. All values have sane defaults if unset.
# Only the variables the current code reads are listed; storage settings
# (DATABASE_URL, pool size) and PUBLIC_BASE_URL are added in later PRs.

# Address the HTTP server binds to.
APP_BIND_ADDR=127.0.0.1:8080

# Max request body size in bytes.
MAX_BODY_BYTES=16384

# tracing filter
RUST_LOG=info
